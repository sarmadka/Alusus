import "Srl/Array.alusus";
import "Srl/String.alusus";
import "Srl/Console.alusus";
use Srl;

func test {
  def a: Array[Int];
  a.add(5);
  a.add(3);
  a.add(74);
  a.add(5);
  a.insert(2, 8);

  def i: Int;
  for i = 0, i < a.getLength(), ++i Console.print("a(%d) = %d\n", i, a(i));

  a.remove(3);
  Console.print("after removing item 3:\n");
  for i = 0, i < a.getLength(), ++i Console.print("a(%d) = %d\n", i, a(i));

  a.clear();
  Console.print("length after clear: %d\n", a.getLength());

  a.add({ 8, 5, 3, 9 });
  Console.print("after adding block of items:\n");
  for i = 0, i < a.getLength(), ++i Console.print("a(%d) = %d\n", i, a(i));

  def b: Array[Int]({ 17, 71, 33 });
  Console.print("after instantiation with a block of items:\n");
  for i = 0, i < b.getLength(), ++i Console.print("b(%d) = %d\n", i, b(i));
};

test();


def r: Array[ref[A]];

class A {
    def i: ref[Int];
    handler this~init() {
        r.add(this);
        Console.print("A~init\n");
    }
    handler this~init(a: ref[A]) {
        r.add(this);
        Console.print("A~init(a)\n");
    }
}

func test2 {
    def a: A;
}
test2();

class B {
    def i: ref[Int];
    handler this~init() {
        Console.print("B~init\n");
    }
    handler this~init(b: ref[B]) {
        Console.print("B~init(b)\n");
    }
}

func test3 {
    def ab: Array[B];
    def b: B;
    ab.add(b);
}
test3();

def as: Array[String]({ String("Array[String]({...})\n") });
Console.print(as(0));

// Test Array.reserve and cover all paths in Array._prepareToModify.
func test4 {
    // Path 1: data == null (fresh array)
    def c: Array[Int];
    c.reserve(5);
    Console.print("bufSize after reserve on empty array: %d\n", c.getBufSize());

    // Path 2: refCount == 1, newMinSize > bufSize (realloc needed)
    def d: Array[Int];
    d.add(1);
    d.add(2);
    Console.print("bufSize before reserve: %d\n", d.getBufSize());
    d.reserve(10);
    Console.print("bufSize after reserve(10): %d\n", d.getBufSize());

    // Path 2: refCount == 1, newMinSize <= bufSize (no-op)
    d.reserve(3);
    Console.print("bufSize after reserve(3) no-op: %d\n", d.getBufSize());

    // Path 3: refCount > 1 (copy-on-write)
    def e: Array[Int];
    e.add(10);
    e.add(20);
    def f: Array[Int](e);
    e.reserve(10);
    Console.print("e bufSize after copy-on-write reserve: %d\n", e.getBufSize());
    Console.print("e length after copy-on-write reserve: %d\n", e.getLength());
    Console.print("f bufSize unaffected: %d\n", f.getBufSize());
    Console.print("f length unaffected: %d\n", f.getLength());
}
test4();
